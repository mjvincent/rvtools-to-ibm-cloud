##############################################################################
# Virtual Server Instance: {{ vm_name }}
# Migrated from VMware via RVTools
##############################################################################

resource "ibm_is_instance" "{{ vm_name_sanitized }}" {
  name    = "{{ vm_name_sanitized }}"
  image   = var.image_id
  profile = "{{ ibm_profile }}"

  primary_network_interface {
    subnet = ibm_is_subnet.subnet.id
  }

  vpc  = ibm_is_vpc.vpc.id
  zone = var.ibm_zone
  keys = [data.ibm_is_ssh_key.ssh_key.id]
}

{% for vm in vms %}
resource "ibm_is_instance" "{{ vm['VM Name']|replace(' ', '_') }}_vsi" {
  name    = "{{ vm['VM Name']|replace(' ', '_') }}-vsi"
  profile = "{{ vm['IBM Profile'] }}"
  # ... (rest of your existing VSI config)
}

# New Storage Attachment Logic
resource "ibm_is_volume" "{{ vm['VM Name']|replace(' ', '_') }}_volume" {
  name     = "{{ vm['VM Name']|replace(' ', '_') }}-data-vol"
  profile  = "{{ vm['Storage Tier'] }}"
  zone     = var.zone
  capacity = {{ vm['Total Storage GB'] }}
}

resource "ibm_is_instance_volume_attachment" "{{ vm['VM Name']|replace(' ', '_') }}_attach" {
  instance = ibm_is_instance.{{ vm['VM Name']|replace(' ', '_') }}_vsi.id
  volume   = ibm_is_volume.{{ vm['VM Name']|replace(' ', '_') }}_volume.id
  name     = "{{ vm['VM Name']|replace(' ', '_') }}-attachment"
}
{% endfor %}
